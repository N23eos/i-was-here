# Network
NEXT_PUBLIC_CHAIN_ID=84532
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Public transport used by wagmi on the frontend. Can equal the public RPC.
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=

# Contract
NEXT_PUBLIC_ATTENDANCE_NFT_ADDRESS=
DEPLOYER_PRIVATE_KEY=
# For `forge verify` on Basescan.
BASESCAN_API_KEY=

# Signing keys
# 32-byte hex key for AES-256-GCM. Move to a managed KMS before mainnet.
SIGNER_MASTER_KEY=

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB

# Paymaster (Pimlico)
# Pimlico Base Sepolia: https://api.pimlico.io/v2/base-sepolia/rpc?apikey=YOUR_KEY
# Pimlico Base mainnet: https://api.pimlico.io/v2/base/rpc?apikey=YOUR_KEY
# Real URL is server-only. Frontend must use NEXT_PUBLIC_PAYMASTER_PROXY_URL.
PAYMASTER_URL=
NEXT_PUBLIC_PAYMASTER_PROXY_URL=/api/paymaster

# IPFS / metadata
PINATA_JWT=
# Public gateway for reading metadata/images.
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# Monitoring
SENTRY_DSN=
