# Network
NEXT_PUBLIC_CHAIN_ID=84532
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Public transport used by wagmi on the frontend (Sprint 01). Can equal the public RPC.
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=

# Contract
NEXT_PUBLIC_ATTENDANCE_NFT_ADDRESS=
DEPLOYER_PRIVATE_KEY=
# For `forge verify` on Basescan (Sprint 02). Not a secret leak — user-provided.
BASESCAN_API_KEY=

# Signing keys
# 32-byte hex key for AES-256-GCM in MVP. Move to CDP KMS before mainnet.
SIGNER_MASTER_KEY=

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB

# Paymaster (CDP)
# Real CDP URL is server-only. Frontend must use NEXT_PUBLIC_PAYMASTER_PROXY_URL.
CDP_PAYMASTER_URL=
NEXT_PUBLIC_PAYMASTER_PROXY_URL=/api/paymaster

# IPFS / metadata
PINATA_JWT=
# Public gateway for reading metadata/images (Sprint 03/04).
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# Monitoring
SENTRY_DSN=
